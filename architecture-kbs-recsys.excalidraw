      "versionNonce": 134,
      "isDeleted": false,
      "boundElements": null,
      "updated": 1,
      "link": null,
      "locked": false,
      "text": "Recommendation + Team Scoring\n\nRecommended Jobs:\nFreelancer skills overlap with Project required skills\n\nRecommended Freelancers:\nProject required skills overlap with Freelancer skills\n\nTeam Formation:\n1. Cover as many project skills as possible\n2. Add synergy from shared graph entities\n3. final_score = technical_score + synergy_score * 0.01\n\nKBS explains every recommendation with graph paths + matched/missing skills",
      "fontSize": 16,
      "fontFamily": 1,
      "textAlign": "left",
      "verticalAlign": "top",
      "containerId": null,
      "originalText": "Recommendation + Team Scoring\n\nRecommended Jobs:\nFreelancer skills overlap with Project required skills\n\nRecommended Freelancers:\nProject required skills overlap with Freelancer skills\n\nTeam Formation:\n1. Cover as many project skills as possible\n2. Add synergy from shared graph entities\n3. final_score = technical_score + synergy_score * 0.01\n\nKBS explains every recommendation with graph paths + matched/missing skills",
      "lineHeight": 1.25,
      "baseline": 225
    },
